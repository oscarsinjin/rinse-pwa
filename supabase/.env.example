# Local dev secrets for `supabase functions serve --env-file supabase/.env`.
# In production, set these with `supabase secrets set KEY=value` instead of committing them.
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically — no need to set them here.

# Get sandbox credentials at https://sandbox.payfast.co.za
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
PAYFAST_MODE=sandbox

# Must match whichever app initiates checkout (the Customer app's app.json "scheme").
APP_RETURN_SCHEME=rinsecustomer
